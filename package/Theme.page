<script>
(function() {
  const form = document.getElementById('modernui-settings');
  if (!form) return;

  // Unraid's PHP-FPM hangs on multipart/form-data POSTs to plugin endpoints,
  // so we serialize as application/x-www-form-urlencoded which works.
  // The form's auto_prepend csrf_token check reads $_POST['csrf_token'].
  function formToUrlEncoded(form) {
    const params = new URLSearchParams();
    for (const [k, v] of new FormData(form)) params.append(k, v);
    return params.toString();
  }

  function post(action) {
    const params = new URLSearchParams();
    params.append('action', action);
    if (typeof csrf_token !== 'undefined') params.append('csrf_token', csrf_token);
    return fetch('/plugins/unraid-modernui/include/save.php', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: params.toString(),
    });
  }

  const dis = document.getElementById('modernui-disable');
  if (dis) dis.addEventListener('click', () => post('disable').then(() => location.reload()));
  const en = document.getElementById('modernui-enable');
  if (en) en.addEventListener('click', () => post('enable').then(() => location.reload()));

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    fetch(form.action, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: formToUrlEncoded(form),
    })
      .then(r => r.json())
      .then(j => {
        if (j.ok) location.reload();
        else alert('Save failed: ' + (j.error || 'unknown'));
      });
  });
})();
</script>
