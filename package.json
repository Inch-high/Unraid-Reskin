{
  "name": "unraid-modernui",
  "version": "0.3.0",
  "private": true,
  "description": "Clean, flat, responsive theme for Unraid 7.x with a rebuilt /Dashboard (hero strip, sticky sidebar, grouped widget cards).",
  "type": "module",
  "scripts": {
    "build": "node tools/build.mjs",
    "package": "node tools/package-txz.mjs",
    "dev-mirror": "node tools/dev-mirror.mjs",
    "test": "npm run test:ts && npm run test:php",
    "test:ts": "vitest run",
    "test:php": "node tests/unit-php/run-all.mjs",
    "test:integration": "node tests/integration/install-uninstall.mjs"
  },
  "devDependencies": {
    "jsdom": "^24.0.0",
    "sass": "^1.77.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "lit": "^3.3.3"
  }
}
